# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Azure Core ────────────────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=ai-agent-skills-rg
AZURE_LOCATION=australiaeast
AZURE_TENANT_ID=your-tenant-id

# ── Azure Container Registry (ACR) ───────────────────────────────────────────
# Note: ACR names must be alphanumeric only, 5-50 chars
AZURE_ACR_NAME=aiskillsacr

# ── Azure Kubernetes Service (AKS) ───────────────────────────────────────────
AZURE_AKS_CLUSTER=ai-agent-skills-aks

# ── Azure API Management (APIM) ───────────────────────────────────────────────
AZURE_APIM_NAME=ai-agent-skills-apim

# ── Azure Key Vault ────────────────────────────────────────────────────────────
AZURE_KEYVAULT_URL=https://ai-agent-skills-kv.vault.azure.net/

# ── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_STORAGE_URL=https://aiskillsstorage.blob.core.windows.net

# ── Azure Service Bus ─────────────────────────────────────────────────────────
AZURE_SERVICEBUS_NAMESPACE=ai-agent-skills-sb.servicebus.windows.net

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── Azure Log Analytics ───────────────────────────────────────────────────────
AZURE_LOG_ANALYTICS_WORKSPACE_ID=your-workspace-id

# ── Azure App Configuration ───────────────────────────────────────────────────
AZURE_APP_CONFIG_URL=https://your-appconfig.azconfig.io

# ── Databricks ────────────────────────────────────────────────────────────────
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your-databricks-token
